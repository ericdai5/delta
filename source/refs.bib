@MISC{Teller2025-pw,
  title     = "{BLOOM}: Simplifying interactive diagram development with
               optimization constraints",
  author    = "Teller, Griffin and Sunshine, Joshua",
  abstract  = "The development of interactive diagrams presents a unique
               challenge compared to their static counterparts by requiring
               authors to specify general procedures for layout rather than
               single configurations. We present BLOOM, a JavaScript library
               that simplifies interactive diagram development through
               optimization constraints. While existing approaches require
               authors to specify the process through which a diagram reacts to
               interaction, BLOOM enables a declarative approach where authors
               specify what properties diagrams should maintain. The properties
               are expressed through constraints solved by numerical
               optimization that map plainly to natural language descriptions.
               We demonstrate BLOOM's advantages through a comparative
               implementation, illustrating how it reduces complexity while
               improving reliability compared to a force-based approach.",
  publisher = "Plateau Workshop",
  month     =  jul,
  year      =  2025
}

